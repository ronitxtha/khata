# ── Server ─────────────────────────────────────────────
PORT=8000

# ── MongoDB Atlas ───────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# ── JWT ─────────────────────────────────────────────────
SECRET_KEY=your_jwt_secret_here

# ── Email — Brevo SMTP (replaces Gmail which is blocked on cloud providers) ─
# Sign up free at brevo.com → Settings → SMTP & API → copy SMTP Password
BREVO_USER=your_brevo_account_email@gmail.com
BREVO_PASS=your_brevo_smtp_key

# ── Email (Gmail — kept for reference, NOT used in production) ─────────────
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_gmail_app_password

# ── eSewa Payment ───────────────────────────────────────
ESEWA_SECRET_KEY=your_esewa_secret_key
ESEWA_PRODUCT_CODE=EPAYTEST

# ── Admin Seed ──────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourSecurePassword123

# ── CORS (set to your Vercel frontend URL after deploy) ─
FRONTEND_URL=https://your-app.vercel.app
